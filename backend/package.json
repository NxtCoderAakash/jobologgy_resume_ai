{
  "name": "elegant-resume-ai-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Plain Node.js (native http, no framework) backend for the AI resume optimizer",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@supabase/supabase-js": "^2.45.4",
    "busboy": "^1.6.0",
    "dotenv": "^16.4.5",
    "mammoth": "^1.8.0",
    "puppeteer": "^23.4.0",
    "tsx": "^4.19.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/busboy": "^1.5.4",
    "@types/node": "^22.7.4",
    "typescript": "^5.6.2"
  }
}
